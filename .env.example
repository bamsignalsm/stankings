# Stankings HQ — required environment variables
# Coolify: set as Environment variables. Mark NEXT_PUBLIC_* as available at build time.
# Never commit real secrets. Docker build does not require a .env.local file.

# Public site URL (production)
NEXT_PUBLIC_SITE_URL=https://stankings.com

# Supabase (Stankings Group project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only (runtime — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Super admin bootstrap identity (email only in production)
SUPER_ADMIN_EMAIL=office@stankings.com

# Optional — surfaced on /api/health
# APP_ENV=production
# DEPLOY_PLATFORM=coolify
# DEPLOY_PROVIDER=hetzner
# APP_VERSION=0.1.0
# GIT_COMMIT_SHA=
# BUILD_TIME=
# NODE_ENV=production
# LOG_LEVEL=info
# COOLIFY_BUILD_UUID=
# SOURCE_COMMIT=

# Local development only (do not set in Coolify)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SUPER_ADMIN_PASSWORD=change-me-locally
# SEED_MEMBER_EMAIL=user@stankings.com
# SEED_MEMBER_PASSWORD=change-me-locally
